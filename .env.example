# RAWAHEL Pulse production environment template

NODE_ENV=production
PORT=3000

# Required in production: at least 32 characters.
JWT_SECRET=replace-with-strong-random-secret-min-32-chars

# Required in production.
DATABASE_URL=mysql://user:password@host:3306/rawahel

# Auth option A: OAuth. Configure these if you have an OAuth portal.
OAUTH_SERVER_URL=https://auth.example.com
VITE_OAUTH_PORTAL_URL=https://auth.example.com
VITE_APP_ID=rawahel-pulse

# Auth option B: production-safe local email/password login.
# Use this for Render/Aiven if OAuth is not available.
# Then run:
# SUPER_ADMIN_EMAIL=admin@example.com SUPER_ADMIN_PASSWORD='change-me-strong-123' pnpm create:super-admin
LOCAL_AUTH_ENABLED=0

# Recommended for first production bootstrap and operator-safe links.
OWNER_OPEN_ID=replace-with-super-admin-open-id
EXTERNAL_SUBMISSION_BASE_URL=https://pulse.example.com

# Optional remote export storage. Leave both empty to use local browser export only.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional: disables the local admin fallback even outside production.
RAWAHEL_DISABLE_LOCAL_ADMIN_FALLBACK=1
